{
  "name": "gulp-boilerplate",
  "version": "0.1.0",
  "private": true,
  "description": "A modular, config-driven Gulp + Dart Sass build system for production frontend projects.",
  "keywords": [
    "gulp",
    "boilerplate",
    "build-system",
    "static-site",
    "esbuild",
    "sass"
  ],
  "homepage": "https://github.com/Vranjan7077/gulp-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/Vranjan7077/gulp-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vranjan7077/gulp-boilerplate.git"
  },
  "license": "ISC",
  "author": "Vinay Ranjan",
  "type": "module",
  "scripts": {
    "build": "tsx node_modules/gulp/bin/gulp.js build --production",
    "build:dev": "tsx node_modules/gulp/bin/gulp.js build",
    "dev": "tsx node_modules/gulp/bin/gulp.js dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"**/*.scss\"",
    "lint:styles:fix": "stylelint \"**/*.scss\" --fix",
    "prepare": "husky",
    "validate:html": "tsx node_modules/gulp/bin/gulp.js validate:html"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.scss": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,html}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@types/browser-sync": "^2.29.1",
    "@types/gulp": "^4.0.17",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/node": "^22.10.5",
    "@types/vinyl": "^2.0.12",
    "autoprefixer": "^10.4.20",
    "browser-sync": "^3.0.3",
    "cssnano": "^7.0.6",
    "esbuild": "^0.25.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "fast-glob": "^3.3.2",
    "globals": "^15.14.0",
    "gulp": "^5.0.0",
    "gulp-plumber": "^1.2.1",
    "gulp-postcss": "^10.0.0",
    "html-minifier-terser": "^7.2.0",
    "html-validate": "^8.24.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "picocolors": "^1.1.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "sharp": "^0.33.5",
    "stylelint": "^16.12.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "svgo": "^3.3.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
